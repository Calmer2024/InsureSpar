# 环境变量（敏感信息）
.env
.env.local
.env.*.local

# Python 缓存文件
__pycache__/
*.pyc
*.pyo
*.pyd

# 默认忽略的文件
/shelf/
/workspace.xml
# 基于编辑器的 HTTP 客户端请求
/httpRequests/
# Datasource local storage ignored files
/dataSources/
/dataSources.local.xml

# 忽略 PyCharm 配置文件
.idea/
*.iws
*.iml
*.ipr

# 忽略 Python 缓存和虚拟环境
*.py[cod]
*$py.class
.venv/
venv/
env/

# 忽略前端依赖和构建产物
node_modules/
dist/
.DS_Store